generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")

  ordersAsCustomer  Order[]        @relation("CustomerOrders")
  ordersCreatedBy   Order[]        @relation("CreatedByOrders")
  shipmentEvents    ShipmentEvent[]
  agent             Agent?

  @@map("users")
}

enum Role {
  customer
  agent
  admin
}

model Zone {
  id   String @id @default(uuid())
  name String @unique

  areas           Area[]
  priceMatrixFrom PriceMatrix[] @relation("FromZone")
  priceMatrixTo   PriceMatrix[] @relation("ToZone")
  ordersOrigin    Order[]       @relation("OriginZone")
  ordersDest      Order[]       @relation("DestZone")
  agents          Agent[]

  @@map("zones")
}

model Area {
  pincode String @id
  zoneId  String @map("zone_id")
  zone    Zone   @relation(fields: [zoneId], references: [id])

  @@map("areas")
}

model PriceMatrix {
  id           String    @id @default(uuid())
  fromZoneId   String    @map("from_zone_id")
  toZoneId     String    @map("to_zone_id")
  orderType    OrderType @map("order_type")
  pricePerKg   Decimal   @map("rate_per_kg") @db.Decimal(10, 2)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  fromZone Zone    @relation("FromZone", fields: [fromZoneId], references: [id])
  toZone   Zone    @relation("ToZone", fields: [toZoneId], references: [id])
  orders   Order[]

  @@unique([fromZoneId, toZoneId, orderType])
  @@map("rate_cards")
}

model CodFeeConfig {
  id        String    @id @default(uuid())
  orderType OrderType @unique @map("order_type")
  type      FeeType
  value     Decimal   @db.Decimal(10, 2)
  isActive  Boolean   @default(true) @map("is_active")

  @@map("cod_surcharge_config")
}

enum FeeType {
  FLAT
  PERCENTAGE

  @@map("SurchargeType")
}

model Agent {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  zoneId      String?  @map("zone_id")
  currentLat  Float?   @map("current_lat")
  currentLng  Float?   @map("current_lng")
  onShift     Boolean  @default(false) @map("clocked_in")
  loadCount   Int      @default(0) @map("active_order_count")
  slotLimit   Int      @default(5) @map("max_capacity")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User  @relation(fields: [userId], references: [id])
  zone   Zone? @relation(fields: [zoneId], references: [id])
  orders Order[]

  @@map("agents")
}

model Order {
  id                  String      @id @default(uuid())
  shipmentCode        String      @unique @default(cuid()) @map("tracking_id")
  customerId          String      @map("customer_id")
  createdById         String      @map("created_by")
  originAddress       String      @map("pickup_address")
  originPincode       String      @map("pickup_pincode")
  originZoneId        String      @map("pickup_zone_id")
  destinationAddress  String      @map("drop_address")
  destinationPincode  String      @map("drop_pincode")
  destinationZoneId   String      @map("drop_zone_id")
  lengthCm            Decimal     @map("length_cm") @db.Decimal(8, 2)
  breadthCm           Decimal     @map("breadth_cm") @db.Decimal(8, 2)
  heightCm            Decimal     @map("height_cm") @db.Decimal(8, 2)
  actualWeightKg      Decimal     @map("actual_weight_kg") @db.Decimal(8, 2)
  chargeableWeightKg  Decimal     @map("billable_weight_kg") @db.Decimal(8, 2)
  orderType           OrderType   @map("order_type")
  paymentType         PaymentType @map("payment_type")
  priceMatrixId       String?     @map("rate_card_id")
  pricingSnapshot     Json        @map("applied_rate_snapshot")
  codFee              Decimal     @default(0) @map("cod_surcharge") @db.Decimal(10, 2)
  charge              Decimal     @db.Decimal(10, 2)
  deliveryStage       OrderStatus @default(CREATED) @map("current_status")
  assignedAgentId     String?     @map("assigned_agent_id")
  deferredDate        DateTime?   @map("reschedule_date") @db.Date
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  customer        User         @relation("CustomerOrders", fields: [customerId], references: [id])
  createdBy       User         @relation("CreatedByOrders", fields: [createdById], references: [id])
  originZone      Zone         @relation("OriginZone", fields: [originZoneId], references: [id])
  destinationZone Zone         @relation("DestZone", fields: [destinationZoneId], references: [id])
  priceMatrix     PriceMatrix? @relation(fields: [priceMatrixId], references: [id])
  assignedAgent   Agent?       @relation(fields: [assignedAgentId], references: [id])
  shipmentEvents  ShipmentEvent[]
  dispatchLogs    DispatchLog[]

  @@map("orders")
}

enum OrderType {
  B2B
  B2C
}

enum PaymentType {
  PREPAID
  COD
}

enum OrderStatus {
  CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

model ShipmentEvent {
  id           String       @id @default(uuid())
  orderId      String       @map("order_id")
  prevStage    OrderStatus? @map("from_status")
  nextStage    OrderStatus  @map("to_status")
  changedById  String       @map("actor_id")
  changedByRole Role        @map("actor_role")
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id])
  changedBy User  @relation(fields: [changedById], references: [id])

  @@map("order_tracking_history")
}

model DispatchLog {
  id        String          @id @default(uuid())
  orderId   String          @map("order_id")
  channel   DispatchChannel
  payload   Json
  status    DispatchStatus  @default(PENDING)
  attempts  Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("notification_outbox")
}

enum DispatchChannel {
  EMAIL
  SMS

  @@map("NotificationChannel")
}

enum DispatchStatus {
  PENDING
  SENT
  FAILED

  @@map("NotificationStatus")
}